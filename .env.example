# NexSell Environment Variables
# Copy this to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── PayPal ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=AWs1bBz...
PAYPAL_CLIENT_SECRET=EB-Ahg...
PAYPAL_WEBHOOK_ID=WH-xxx...
PAYPAL_MERCHANT_ID=YOUR_MERCHANT_ID
PAYPAL_SANDBOX=true  # Set to false for production

# ── OpenRouter (https://openrouter.ai) ───────────────────
# OpenRouter gives access to 100+ models via OpenAI-compatible API
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model (change to any model OpenRouter supports)
AI_MODEL=openai/gpt-4o
AI_EMBEDDING_MODEL=openai/text-embedding-3-large

# ── Search ────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=...
MEILISEARCH_HOST=https://your-index.meilisearch.io
MEILISEARCH_API_KEY=...

# ── Email ─────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cache (Vercel KV / Redis) ────────────────────────────
KV_REST_API_URL=https://your-kv.vercel-storage.com
KV_REST_API_TOKEN=...

# ── App ──────────────────────────────────────────────────
# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AWs1bBz...
NODE_ENV=development
CRON_SECRET=change-me-to-a-random-string
GITHUB_TOKEN=ghp_...
GITHUB_REPO_OWNER=ibdmaibot-southafrica
GITHUB_REPO_NAME=NexSell
